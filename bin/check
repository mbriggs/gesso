#!/usr/bin/env bash
#
# Verification gate: format, shellcheck, build, vet, stock linters, tidy
# drift, templ drift, dead CSS, tests.

set -euo pipefail
cd "$(dirname "$0")/.."

unformatted=$(gofumpt -l . 2>/dev/null || true)
if [ -n "$unformatted" ]; then
  echo "gofumpt needed on:"
  echo "$unformatted"
  exit 1
fi

shellcheck -x -s bash bin/*

go build ./...
go vet ./...

if command -v golangci-lint >/dev/null; then
  golangci-lint run ./...
else
  echo "warning: golangci-lint not installed, skipping stock linters" >&2
fi

go mod tidy -diff

# Stale = regeneration changed something the index doesn't have: untracked
# new output (??) or a worktree modification (second status column set).
bin/generate
drift=$(git status --porcelain -- '*_templ.go' | grep -E '^(\?\?|.[^ ])' || true)
if [ -n "$drift" ]; then
  echo "generated code is stale or untracked — commit bin/generate output:"
  echo "$drift"
  exit 1
fi

go run ./cmd/cssdead

go test ./...

echo "all checks passed"
