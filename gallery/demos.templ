			{Kind: ui.FlashSuccess, Title: "Saved", Message: "Saved 3 families."},
			{Kind: ui.FlashAlert, Message: "Try another email address or password."},
			{Kind: ui.FlashError, Title: "Save failed", Message: "Fix the issues above and try again."},
		}})
	</div>
}

templ designDemoConfirmInterceptor() {
	<div class="stack gap-sm">
		<div class="design-row">
			<form method="get" action="#confirm-interceptor" data-ui-confirm="Default copy everywhere else — Confirm resubmits this demo form.">
				@ui.Button(ui.ButtonProps{Type: "submit", Variant: "secondary", Text: "Submit with confirm"})
			</form>
			<form method="get" action="#confirm-interceptor">
				@ui.Button(ui.ButtonProps{
					Type:    "submit",
					Variant: "danger",
					Text:    "Archive (overrides)",
					Attrs: ui.Attrs(
						"data-ui-confirm", "It'll be hidden by default. Toggle “Show archived” at the top to bring it back into view.",
						"data-ui-confirm-title", "Archive \"Business cards\"?",
						"data-ui-confirm-label", "Archive",
						"data-ui-confirm-tone", "danger",
					),
				})
			</form>
			@ui.ButtonLink(ui.LinkButtonProps{Href: "#confirm-interceptor", Variant: "link", Text: "Link with confirm", Attrs: ui.Attrs("data-ui-confirm", "Links work too — Confirm follows the href.")})
		</div>
		<p style="font-size: var(--text-sm); color: var(--text-muted)">One dialog per layout (ui.GlobalConfirm) serves every element carrying data-ui-confirm; per-element attributes override title, labels, and tone.</p>
		@ui.GlobalConfirm()
	</div>
}

