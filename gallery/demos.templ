templ designDemoProse() {
	@ui.Prose(ui.ProseProps{Content: designProseBody()})
}

templ designProseBody() {
	<h1>Substrate handling</h1>
	<p>
		Long-form copy gets a 65ch measure, a relaxed line height, and the
		<a href="#prose">link voice</a> of the rest of the system. Inline
		<code>code spans</code> and <strong>strong runs</strong> keep their place
		in the rhythm.
	</p>
	<h2>Press checklist</h2>
	<ul>
		<li>Verify the substrate's print group before queuing.</li>
		<li>Dimensional weight drives the freight estimate.</li>
		<li>Archived substrates never reach the storefront.</li>
	</ul>
	<blockquote>Ship the proof before the press run — every time.</blockquote>
	<pre><code>{ designProseSample }</code></pre>
	<h3>Tolerances</h3>
	<table>
		<thead>
			<tr><th>Stock</th><th>Weight</th><th>Tolerance</th></tr>
		</thead>
		<tbody>
			<tr><td>Silk cover</td><td>16pt</td><td>±0.4pt</td></tr>
			<tr><td>Uncoated cover</td><td>14pt</td><td>±0.6pt</td></tr>
		</tbody>
	</table>
}

