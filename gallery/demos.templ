templ designUnsavedForm() {
	<form data-ui-dirty-guard action="#unsaved-changes" method="get">
		<div class="stack gap-md">
			@ui.Field(ui.FieldProps{ID: "design-dirty-name", Label: "Family name", Hint: "Baseline from the rendered value — edit to arm the guard.", Control: ui.Input(ui.InputProps{ID: "design-dirty-name", Name: "name", Value: "Business cards"})})
			@ui.Field(ui.FieldProps{ID: "design-dirty-code", Label: "Harmonize code", Hint: "Baseline pinned via data-baseline-value.", Control: ui.Input(ui.InputProps{ID: "design-dirty-code", Name: "code", Value: "4911.99", Mono: true, Attrs: ui.Attrs("data-baseline-value", "4911.99")})})
			<p class="design-dirty-note">Dirty — the form now carries data-ui-dirty="true" and navigating away warns.</p>
			<div class="form-actions">
				<button type="reset" class={ ui.ButtonClasses("secondary", "") }>Reset</button>
				@ui.Button(ui.ButtonProps{Type: "submit", Text: "Save"})
			</div>
		</div>
	</form>
}

templ designDemoSwap() {
	@ui.Prose(ui.ProseProps{Content: designSwapDoc()})
}

templ designSwapDoc() {
	<p>
		A form opting in with <code>data-ui-swap</code> posts via
		<code>fetch</code> and patches the page in place — no client templates,
		no JSON. Without JS it submits natively and the server renders the full
		page.
	</p>
	<ul>
		<li>The request carries <code>X-UI-Swap: 1</code> so the handler can branch fragment-render vs redirect.</li>
		<li>The response is <code>text/html</code>: every top-level element with an <code>id</code> replaces the document element with the same id; fragments without a counterpart are ignored. Error re-renders (422) use the same shape.</li>
		<li>A redirected response is followed as a full navigation, preserving POST→redirect→GET for handlers that don't fragment-render.</li>
		<li>After patching, a <code>ui:swap</code> event fires on <code>document</code> with the swapped ids, for focus restore and friends.</li>
	</ul>
	<pre><code>{ designSwapSample }</code></pre>
}

