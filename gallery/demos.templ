templ designDemoProductSurface() {
	<div class="design-product-surface">
		@ui.PageHeader(ui.PageHeaderProps{
			Eyebrow:     designEyebrowFAM(),
			Breadcrumbs: designProductCrumbs(),
			Title:       "Business cards",
			Sub:         "Coated stock family with four substrates and two configurable option groups.",
			Badges:      designProductBadges(),
			Actions:     designProductActions(),
		})
		<dl class="metric-grid design-product-metrics">
			<div class="metric primary">
				<dt>Substrates</dt>
				<dd>4</dd>
			</div>
			<div class="metric info">
				<dt>Options</dt>
				<dd>2</dd>
			</div>
			<div class="metric warning">
				<dt>Open jobs</dt>
				<dd>18</dd>
			</div>
			<div class="metric success">
				<dt>Errors</dt>
				<dd>0</dd>
			</div>
		</dl>
		<div class="design-product-grid">
			<section class="design-product-panel">
				<div class="design-product-panel-head">
					<h3>Production state</h3>
					@ui.Badge(ui.BadgeProps{Tone: ui.ToneWarning, Text: "queued"})
				</div>
				@ui.StageBar(ui.StageBarProps{
					Variant: ui.StageBarEmbedded,
					Current: "press",
					Stages: []ui.Stage{
						{Key: "catalog", Label: "Catalog", Hint: "Ready", Status: ui.StatusCompleted},
						{Key: "proof", Label: "Proof", Hint: "Approved", Status: ui.StatusCompleted},
						{Key: "press", Label: "Press", Hint: "Queued", Status: ui.StatusActive},
						{Key: "ship", Label: "Ship", Hint: "Waiting", Status: ui.StatusPending},
					},
				})
			</section>
			<section class="design-product-panel">
				<div class="design-product-panel-head">
					<h3>Substrate readiness</h3>
					@ui.Badge(ui.BadgeProps{Tone: ui.ToneSuccess, Text: "4 ready"})
				</div>
				@ui.TableFrame(ui.TableFrameProps{Content: designProductTable()})
			</section>
		</div>
	</div>
}

